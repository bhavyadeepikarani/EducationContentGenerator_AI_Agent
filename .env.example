# ─────────────────────────────────────────────
#  EduGen AI Agent — Environment Variables
#  Copy this file to `.env` and fill values
# ─────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────
# Choose one provider: openai | google
LLM_PROVIDER=openai

# OpenAI (if using GPT)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini (if using Google LLM)
GOOGLE_API_KEY=XXXXX


# ── Google Cloud (Docs, TTS, Drive) ──────────
GOOGLE_APPLICATION_CREDENTIALS=./config/google_service_account.json
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# OAuth (for Google Docs user login)
GOOGLE_DOCS_CLIENT_ID=your_oauth_client_id
GOOGLE_DOCS_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_DOCS_REDIRECT_URI=http://localhost:8501


# ── YouTube Data API ─────────────────────────
YOUTUBE_API_KEY=your_youtube_data_api_key_here


# ── Educational Platforms ────────────────────
# (Scraping-based — no API keys required)
NPTEL_BASE_URL=https://nptel.ac.in
SWAYAM_BASE_URL=https://swayam.gov.in


# ── Anki Integration ─────────────────────────
ANKI_CONNECT_URL=http://localhost:8765
ANKI_DEFAULT_DECK=Educational Agent


# ── Quizlet (optional / unofficial) ──────────
QUIZLET_CLIENT_ID=your_quizlet_client_id
QUIZLET_CLIENT_SECRET=your_quizlet_client_secret


# ── Application Settings ─────────────────────
APP_NAME=EduGen AI Agent
APP_ENV=development
LOG_LEVEL=INFO

# Limits
MAX_PDF_PAGES=100
MAX_YOUTUBE_DURATION_MINUTES=60

# Output directories
AUDIO_OUTPUT_DIR=./data/generated/audio
QUIZ_OUTPUT_DIR=./data/generated/quizzes
FLASHCARD_OUTPUT_DIR=./data/flashcards
UPLOAD_DIR=./data/uploads


# ── Vector Database (ChromaDB) ───────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=edu_content


# ── SQLite Database ──────────────────────────
DB_PATH=./data/student_progress.db
